{
  "name": "goaltracker",
  "version": "1.0.0",
  "type": "module",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer && electron-builder"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.abhis.goaltracker",
    "productName": "GoalTracker",
    "asar": true,
    "files": [
      "main.js",
      "preload.cjs",
      "services/**/*",
      "storage/**/*",
      "renderer/dist/**/*"
    ],
    "win": {
      "target": "portable",
      "forceCodeSigning": false
    }
  }
}
